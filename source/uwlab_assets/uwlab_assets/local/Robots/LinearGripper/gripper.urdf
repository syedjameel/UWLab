<?xml version="1.0"?>
<!--
  Linear parallel-jaw gripper, links/joints RENAMED to match the OmniReset
  Robotiq-2F85 integration contract so the existing task code (actions, grasp
  sampler, reset events) works with minimal edits:
    base_link       -> robotiq_base_link   (gripper root / EE frame)
    left_jaw_link   -> left_inner_finger    (finger contact body)
    right_jaw_link  -> right_inner_finger   (finger contact body)
    left_jaw_joint  -> finger_joint         (the single actuated driver joint)
    right_jaw_joint -> right_finger_joint   (mimics finger_joint)
  Geometry, inertials, limits, dynamics and the mimic are UNCHANGED from the
  original gripper.urdf. NOTE: kinematically, finger_joint = 0 is fully OPEN
  (jaws widest); increasing it CLOSES the jaws toward the center.
-->
<robot name="linear_gripper">
  <mujoco>
    <compiler meshdir="meshes" discardvisual="false"/>
  </mujoco>

  <link name="robotiq_base_link">
    <inertial>
      <origin xyz="0 0 0.0055" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.001245" ixy="0" ixz="0" iyy="0.002728" iyz="0" izz="0.003051"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="left_inner_finger">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000151" ixy="0" ixz="0" iyy="0.000258" iyz="0" izz="0.000156"/>
    </inertial>
    <visual>
      <origin xyz="-0.041639558 -0.013 -0.04754972" rpy="0 0 0"/>
      <geometry>
        <mesh filename="tip.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.041639558 -0.013 -0.04754972" rpy="0 0 0"/>
      <geometry>
        <mesh filename="tip.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="right_inner_finger">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000151" ixy="0" ixz="0" iyy="0.000258" iyz="0" izz="0.000156"/>
    </inertial>
    <visual>
      <origin xyz="0.041639558 0.013 -0.04754972" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="tip.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.041639558 0.013 -0.04754972" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="tip.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- Single actuated driver joint. finger_joint=0 -> jaws fully OPEN (widest);
       increasing moves the left jaw +X toward center -> CLOSING. -->
  <joint name="finger_joint" type="prismatic">
    <parent link="robotiq_base_link"/>
    <child link="left_inner_finger"/>
    <origin xyz="-0.04488 0.000189 0.09354972" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.068" effort="120" velocity="0.05"/>
    <dynamics damping="8" friction="1"/>
  </joint>

  <!-- The second jaw mimics finger_joint and moves the opposite way along -X. -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="robotiq_base_link"/>
    <child link="right_inner_finger"/>
    <origin xyz="0.04488 0.000189 0.09354972" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.068" effort="120" velocity="0.05"/>
    <dynamics damping="8" friction="1"/>
    <mimic joint="finger_joint" multiplier="1" offset="0"/>
  </joint>

  <transmission name="finger_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="finger_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="linear_actuator">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</robot>
